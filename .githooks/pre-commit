#!/bin/bash

# Auto-bump patch version in plugin.json and marketplace.json on every commit
PLUGIN_JSON=".claude-plugin/plugin.json"
MARKETPLACE_JSON=".claude-plugin/marketplace.json"

current_version=$(grep -o '"version": "[^"]*"' "$PLUGIN_JSON" | head -1 | grep -o '[0-9]*\.[0-9]*\.[0-9]*')
major=$(echo "$current_version" | cut -d. -f1)
minor=$(echo "$current_version" | cut -d. -f2)
patch=$(echo "$current_version" | cut -d. -f3)
new_version="$major.$minor.$((patch + 1))"

sed -i '' "s/\"version\": \"$current_version\"/\"version\": \"$new_version\"/" "$PLUGIN_JSON" "$MARKETPLACE_JSON"
git add "$PLUGIN_JSON" "$MARKETPLACE_JSON"
